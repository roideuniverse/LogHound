root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 4
trim_trailing_whitespace = true
max_line_length = 120

[*.{md,markdown}]
trim_trailing_whitespace = false

[*.{kt,kts}]
indent_size = 4
ij_kotlin_imports_layout = *

[*.{yml,yaml,json}]
indent_size = 2
